<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>CleanUp Pro</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background: #f4f6f8;
    }
    header {
      background: #2ecc71;
      color: white;
      padding: 20px;
      text-align: center;
    }
    .container {
      padding: 30px;
      max-width: 800px;
      margin: auto;
    }
    .card {
      background: white;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    input, textarea, button {
      width: 100%;
      margin-top: 10px;
      padding: 10px;
      border-radius: 6px;
      border: 1px solid #ccc;
      font-size: 16px;
    }
    button {
      background: #2ecc71;
      color: white;
      border: none;
      cursor: pointer;
    }
    button:hover {
      background: #27ae60;
    }
    .tasks {
      margin-top: 20px;
    }
    .task {
      background: #ecf0f1;
      padding: 10px;
      border-radius: 6px;
      margin-top: 10px;
    }
  </style>
</head>
<body>

<header>
  <h1>CleanUp Pro</h1>
  <p>Servicio de limpieza rápida y eficiente</p>
</header>

<div class="container">
  <div class="card">
    <h2>¿Qué necesitas limpiar hoy?</h2>
    <textarea id="taskInput" placeholder="Ej: limpiar cocina, aspirar sala..."></textarea>
    <button onclick="addTask()">Agregar solicitud</button>

    <div class="tasks" id="taskList"></div>
  </div>
</div>

<script>
  function addTask() {
    const input = document.getElementById("taskInput");
    const text = input.value.trim();

    if (text === "") {
      alert("Escribe algo primero bro");
      return;
    }

    const taskList = document.getElementById("taskList");

    const div = document.createElement("div");
    div.className = "task";
    div.textContent = text;

    taskList.appendChild(div);

    input.value = "";
  }
</script>

</body>
</html>
